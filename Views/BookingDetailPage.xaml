<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:VillaBookingMAUI.ViewModels"
             x:Class="VillaBookingMAUI.Views.BookingDetailPage"
             x:DataType="vm:BookingDetailViewModel"
             Title="{Binding Title}"
             BackgroundColor="#1A1A2E">

    <ScrollView>
        <VerticalStackLayout Spacing="0" Padding="20">

            <!-- Зареждане -->
            <ActivityIndicator IsRunning="{Binding IsBusy}"
                               IsVisible="{Binding IsBusy}"
                               Color="#3498DB"
                               Margin="0,40,0,0" />

            <!-- Грешка -->
            <Frame IsVisible="{Binding HasError}"
                   BackgroundColor="#E74C3C"
                   CornerRadius="8"
                   Padding="12"
                   Margin="0,20,0,0"
                   HasShadow="False">
                <Label Text="{Binding ErrorMessage}"
                       TextColor="White"
                       HorizontalTextAlignment="Center" />
            </Frame>

            <!-- Съдържание -->
            <VerticalStackLayout IsVisible="{Binding IsLoaded}" Spacing="16">

                <!-- Хедър с име и къща -->
                <Frame BackgroundColor="#16213E"
                       CornerRadius="14"
                       Padding="20"
                       HasShadow="False"
                       Margin="0,8,0,0">
                    <VerticalStackLayout Spacing="8">
                        <Label Text="{Binding Booking.ClientName}"
                               FontSize="24"
                               FontAttributes="Bold"
                               TextColor="#ECF0F1" />
                        <Label Text="{Binding Booking.HouseDisplayName}"
                               FontSize="16"
                               TextColor="#3498DB" />

                        <BoxView HeightRequest="1"
                                 Color="#2C3E50"
                                 Margin="0,4" />

                        <!-- Депозит статус -->
                        <HorizontalStackLayout Spacing="8">
                            <BoxView WidthRequest="12" HeightRequest="12"
                                     CornerRadius="6"
                                     Color="{Binding Booking.DepositColor}" />
                            <Label Text="{Binding Booking.DepositStatus, StringFormat='Депозит: {0}'}"
                                   TextColor="#BDC3C7"
                                   FontSize="14" />
                        </HorizontalStackLayout>
                    </VerticalStackLayout>
                </Frame>

                <!-- Детайли -->
                <Frame BackgroundColor="#16213E"
                       CornerRadius="14"
                       Padding="20"
                       HasShadow="False">
                    <Grid RowDefinitions="Auto,Auto,Auto,Auto,Auto"
                          ColumnDefinitions="Auto,*"
                          RowSpacing="14"
                          ColumnSpacing="16">

                        <Label Grid.Row="0" Grid.Column="0"
                               Text="Период:"
                               TextColor="#7F8C8D" FontSize="14" />
                        <Label Grid.Row="0" Grid.Column="1"
                               Text="{Binding Booking.DateRange}"
                               TextColor="#ECF0F1" FontSize="14"
                               FontAttributes="Bold" />

                        <Label Grid.Row="1" Grid.Column="0"
                               Text="Нощувки:"
                               TextColor="#7F8C8D" FontSize="14" />
                        <Label Grid.Row="1" Grid.Column="1"
                               Text="{Binding Booking.Nights}"
                               TextColor="#ECF0F1" FontSize="14"
                               FontAttributes="Bold" />

                        <Label Grid.Row="2" Grid.Column="0"
                               Text="Гости:"
                               TextColor="#7F8C8D" FontSize="14" />
                        <Label Grid.Row="2" Grid.Column="1"
                               Text="{Binding Booking.GuestsDisplay}"
                               TextColor="#ECF0F1" FontSize="14"
                               FontAttributes="Bold" />

                        <Label Grid.Row="3" Grid.Column="0"
                               Text="Къща:"
                               TextColor="#7F8C8D" FontSize="14" />
                        <Label Grid.Row="3" Grid.Column="1"
                               Text="{Binding Booking.HouseDisplayName}"
                               TextColor="#ECF0F1" FontSize="14"
                               FontAttributes="Bold" />

                        <Label Grid.Row="4" Grid.Column="0"
                               Text="Създадена от:"
                               TextColor="#7F8C8D" FontSize="14" />
                        <Label Grid.Row="4" Grid.Column="1"
                               Text="{Binding Booking.CreatedBy}"
                               TextColor="#ECF0F1" FontSize="14"
                               FontAttributes="Bold" />
                    </Grid>
                </Frame>

                <!-- Действия -->
                <VerticalStackLayout Spacing="10" Margin="0,8,0,0">

                    <Button Text="Редактирай"
                            Command="{Binding EditBookingCommand}"
                            BackgroundColor="#3498DB"
                            TextColor="White"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            HeightRequest="48" />

                    <Button Text="Сподели"
                            Command="{Binding ShareBookingCommand}"
                            BackgroundColor="#16213E"
                            TextColor="#3498DB"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            HeightRequest="48"
                            BorderColor="#3498DB"
                            BorderWidth="1" />

                    <Button Text="Изтрий резервацията"
                            Command="{Binding DeleteBookingCommand}"
                            BackgroundColor="#16213E"
                            TextColor="#E74C3C"
                            FontAttributes="Bold"
                            CornerRadius="10"
                            HeightRequest="48"
                            BorderColor="#E74C3C"
                            BorderWidth="1"
                            Margin="0,8,0,20" />
                </VerticalStackLayout>

            </VerticalStackLayout>
        </VerticalStackLayout>
    </ScrollView>

</ContentPage>
